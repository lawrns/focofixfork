{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foco.mx/schemas/cofounder-policy.v1.json",
  "title": "CoFounderPolicy",
  "type": "object",
  "required": [
    "mode",
    "profile",
    "overnightWindow",
    "hardLimits",
    "actionPolicies",
    "trustGates"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["off", "advisor", "bounded", "near_full"]
    },
    "profile": {
      "type": "string",
      "enum": ["advisor_first", "bounded_operator", "revenue_only", "near_full"]
    },
    "overnightWindow": {
      "type": "object",
      "required": ["enabled", "timezone", "start", "end"],
      "properties": {
        "enabled": { "type": "boolean" },
        "timezone": { "type": "string", "minLength": 1 },
        "start": { "type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$" },
        "end": { "type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$" }
      },
      "additionalProperties": false
    },
    "hardLimits": {
      "type": "object",
      "required": [
        "spendCapUsdPerWindow",
        "maxExternalMessages",
        "maxLiveExperiments",
        "allowProductionDeploys"
      ],
      "properties": {
        "spendCapUsdPerWindow": { "type": "number", "minimum": 0 },
        "maxExternalMessages": { "type": "integer", "minimum": 0 },
        "maxLiveExperiments": { "type": "integer", "minimum": 0 },
        "allowProductionDeploys": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "actionPolicies": {
      "type": "object",
      "required": ["allowedDomains", "blockedActionTypes", "requireApprovalActionTypes"],
      "properties": {
        "allowedDomains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blockedActionTypes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "requireApprovalActionTypes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "trustGates": {
      "type": "object",
      "required": ["minConfidenceToExecute", "minTrustScoreToRaiseAutonomy"],
      "properties": {
        "minConfidenceToExecute": { "type": "number", "minimum": 0, "maximum": 1 },
        "minTrustScoreToRaiseAutonomy": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
