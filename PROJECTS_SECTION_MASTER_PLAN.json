      "phase": 1,
      "name": "Critical Bug Fix & Database Alignment",
      "priority": "P0-CRITICAL",
      "duration": "2-3 days",
      "summary": "Fix the root cause of 'failed to load projects' - database schema mismatch between code expectations and actual tables. Standardize on FOCO 2.0 schema.",
      "issues_addressed": [
        "DB-001: Dual schema problem - code expects foco_workspaces/foco_projects but migrations create workspaces/projects",
        "DB-002: RLS policy recursion causing infinite loops",
        "DB-003: Missing workspace membership for users",
        "DB-004: Type definition mismatch in database.types.ts"
      ],
      "tasks": [
        {
          "id": "P1-T1",
          "title": "Audit and align table names",
          "description": "Ensure all code references use consistent table names. Repository layer expects 'foco_workspaces', 'foco_projects' - verify migrations match.",
          "files_to_check": [
            "src/lib/repositories/workspace-repository.ts",
            "src/lib/repositories/project-repository.ts",
            "supabase/migrations/100_foco_2_core_schema.sql",
            "supabase/migrations/20260115_create_workspaces_and_fix_projects.sql"
          ],
          "decision_required": "Choose canonical naming: foco_* prefix or no prefix. Recommendation: standardize on foco_* for FOCO 2.0 tables."
        },
        {
          "id": "P1-T2",
          "title": "Fix RLS recursion in workspace_members",
          "description": "The RLS policy on foco_workspace_members causes infinite recursion when querying across tables. Rewrite to use workspace-based checks instead of self-referential queries.",
          "problematic_policy": "CREATE POLICY ... USING (EXISTS (SELECT 1 FROM foco_workspace_members WHERE ...))",
          "solution": "Use direct workspace_id comparison or auth.uid() membership check without subqueries on same table"
        },
        {
          "id": "P1-T3",
          "title": "Ensure user workspace membership",
          "description": "Verify the current user is in foco_workspace_members table for at least one workspace. If not, create default workspace and membership.",
          "validation_query": "SELECT * FROM foco_workspace_members WHERE user_id = auth.uid();"
        },
        {
          "id": "P1-T4",
          "title": "Sync TypeScript types with database",
          "description": "Update src/lib/supabase/types.ts to match actual database schema. Remove or update src/types/database.types.ts which has incorrect legacy definitions.",
          "action": "Generate fresh types from Supabase or manually align to foco_* tables"
        },
        {
          "id": "P1-T5",
          "title": "Verify API routes use correct schema",
          "description": "Check all projects API routes use the correct table names and RLS bypass strategy.",
          "files": [
            "src/app/api/projects/route.ts",
            "src/app/api/workspaces/[id]/projects/route.ts"
          ]
        }
      ],
      "success_criteria": [
        "Projects page loads without 'failed to load' error",
        "API returns 200 with project data",
        "No RLS recursion errors in logs",
        "TypeScript types match database schema"
      ]
    },
